__pycache__/
*.py[cod]
*$py.class

# Type-checker / linter caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/

# OS / editor cruft
.DS_Store
